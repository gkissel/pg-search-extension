{
	"$schema": "https://www.schemastore.org/tsconfig",
	"display": "Node 24",
	"_version": "24.0.0",

	"compilerOptions": {
		"lib": [
			"es2024",
			"ESNext.Array",
			"ESNext.Collection",
			"ESNext.Error",
			"ESNext.Iterator",
			"ESNext.Promise"
		],

		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"types": ["node", "vitest/globals"]
	},
	"include": ["**/*.ts", "**/*.tsx", "test/**/*"],
	"exclude": ["node_modules", "dist"]
}
